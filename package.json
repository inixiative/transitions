{
  "name": "@inixiative/transitions",
  "version": "0.1.0",
  "description": "Declarative, serializable transition guard + affordance layer on top of @inixiative/json-rules",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint && bun run test",
    "prepare": "lefthook install",
    "prepublishOnly": "bun run check && bun run build"
  },
  "keywords": [
    "transition",
    "state",
    "lifecycle",
    "guard",
    "json-rules",
    "rebac",
    "typescript"
  ],
  "author": "Aron Greenspan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inixiative/transitions.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@inixiative/config": "^0.3.0",
    "@types/bun": "1.3.14",
    "@types/lodash-es": "^4.17.12",
    "lefthook": "2.1.9",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "@inixiative/json-rules": "^2.13.0",
    "@inixiative/permissions": "^0.3.2",
    "lodash-es": "^4.18.1",
    "zod": "^4.4.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "packageManager": "bun@1.3.14"
}
